{
  "name": "@verichain/desktop-agent",
  "version": "1.0.0",
  "main": "src/main/index.js",
  "scripts": {
    "start": "concurrently -k -n RENDERER,ELECTRON \"vite\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "renderer": "vite",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "dev": "electron . --inspect"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "circomlib": "^2.0.5",
    "dotenv": "^16.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "snarkjs": "^0.7.1",
    "socket.io-client": "^4.8.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "typescript": "^4.9.5",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
