# ─── Gateway ────────────────────────────────────────────────────────
GATEWAY_PORT=CHANGE_ME
NODE_ENV=CHANGE_ME
JWT_SECRET=CHANGE_ME_RANDOM_256BIT_SECRET

# ─── MongoDB ────────────────────────────────────────────────────────
MONGO_ROOT_USER=CHANGE_ME
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MONGODB_URI=CHANGE_ME_mongodb://user:password@mongodb:27017/verichain

# ─── Redis ──────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_URL=CHANGE_ME_redis://:password@redis:6379

# ─── Blockchain ─────────────────────────────────────────────────────
BLOCKCHAIN_RPC=CHANGE_ME_http://blockchain:8545
ACCESS_POLICY_ADDRESS=CHANGE_ME_0x...deployed_address
AUDIT_LEDGER_ADDRESS=CHANGE_ME_0x...deployed_address
GATEWAY_PRIVATE_KEY=CHANGE_ME_0x...hardhat_account_private_key

# ─── AI Engine ──────────────────────────────────────────────────────
AI_HMAC_SECRET=CHANGE_ME_RANDOM_256BIT_SECRET
AI_ENGINE_URL=CHANGE_ME_http://ai-engine:5001

# ─── mTLS ───────────────────────────────────────────────────────────
GATEWAY_CERT_PIN=CHANGE_ME_sha256//base64_encoded_cert_fingerprint

# ─── Frontend Origins ────────────────────────────────────────────────
DESKTOP_AGENT_ORIGIN=CHANGE_ME_https://localhost:8443
TRUST_DASHBOARD_ORIGIN=CHANGE_ME_http://localhost:3001
REACT_APP_GATEWAY_URL=CHANGE_ME_https://localhost:8443
REACT_APP_WS_URL=CHANGE_ME_wss://localhost:8443

# ─── Environment ────────────────────────────────────────────────────
ENVIRONMENT=CHANGE_ME_development_or_production
