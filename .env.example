# ─── Gateway ────────────────────────────────────────────────────────
GATEWAY_PORT=
NODE_ENV=development
JWT_SECRET=
HMAC_SECRET=

MONGO_ROOT_USER=
MONGO_ROOT_PASSWORD=
MONGODB_URI=


REDIS_PASSWORD=
REDIS_URL=


BLOCKCHAIN_RPC=
ACCESS_POLICY_ADDRESS=
AUDIT_LEDGER_ADDRESS=
GATEWAY_PRIVATE_KEY=

# ─── AI Engine ──────────────────────────────────────────────────────
AI_HMAC_SECRET=
AI_ENGINE_URL=

# ─── mTLS ───────────────────────────────────────────────────────────
# This pin is regenerated by start-all.ps1 from the freshly-issued gateway.crt
# and injected into the Desktop Agent process directly, so the value here is
# only a placeholder for non-script runs.
GATEWAY_CERT_PIN=

# ─── Admin API (gateway and dashboard share this exact value) ───────
ADMIN_API_KEY=
REACT_APP_ADMIN_API_KEY=

# ─── Frontend Origins ────────────────────────────────────────────────
DESKTOP_AGENT_ORIGIN=
TRUST_DASHBOARD_ORIGIN=
REACT_APP_GATEWAY_URL=
REACT_APP_WS_URL=

# ─── Environment ────────────────────────────────────────────────────
ENVIRONMENT=development
