{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["./node_modules/@types"],
    "types": ["node"],
    "allowJs": true,
    "noEmit": true
  },
  "include": ["scripts/**/*.js"],
  "exclude": ["node_modules", "**/dist/*"]
}
